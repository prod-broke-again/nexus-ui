{
  "name": "nexus-ui",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "description": "Presentation-only Nexus (Nx) Messenger UI primitives for Vue 3 — props in, emits out.",
  "license": "MIT",
  "main": "./dist/nexus-ui.umd.cjs",
  "module": "./dist/nexus-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/nexus-ui.js",
      "require": "./dist/nexus-ui.umd.cjs"
    },
    "./dist/style.css": "./dist/style.css",
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "~5.6.3",
    "vite": "^6.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.8"
  },
  "scripts": {
    "prepare": "npm run build",
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview"
  },
  "keywords": [
    "vue",
    "vue3",
    "component-library",
    "nexus",
    "ui"
  ],
  "sideEffects": [
    "*.css",
    "**/*.css"
  ]
}
